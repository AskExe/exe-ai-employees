{
  "name": "exe-ai-employees",
  "version": "1.5.8",
  "description": "AI employees for Claude Code. Persistent memory, semantic search, and agent identity via MCP.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/AskExe/exe-ai-employees.git"
  },
  "homepage": "https://github.com/AskExe/exe-ai-employees",
  "keywords": [
    "claude-code",
    "claude",
    "mcp",
    "memory",
    "ai-agents",
    "ai-employees",
    "multi-agent",
    "embeddings",
    "vector-search",
    "libsql",
    "rag",
    "model-context-protocol"
  ],
  "bin": {
    "exe-ai": "./dist/bin/install.js"
  },
  "files": [
    "dist",
    "src/commands",
    "package.json",
    "LICENSE"
  ],
  "exports": {
    "./lib/*": "./dist/lib/*.js",
    "./hooks/*": "./dist/hooks/*.js",
    "./mcp/server": "./dist/mcp/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "deploy": "tsup && npm install -g . && node dist/bin/install.js --global",
    "postinstall": "node dist/bin/install.js --commands-only 2>/dev/null || true",
    "prepublishOnly": "npm run typecheck && npm run build && npm run test"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bip39": "^3.1.0",
    "keytar": "^7.9.0",
    "node-llama-cpp": "^3.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
