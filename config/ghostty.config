# ============================================================================
# Ghostty config for exe-ai-employees
# ============================================================================
#
# Terminal setup optimized for running multiple AI employees via tmux.
# Every keybinding maps macOS-native Cmd shortcuts to tmux prefix
# sequences so you can manage agent sessions without memorizing
# Ctrl+B combos.
#
# Install:
#   macOS:  mkdir -p ~/.config/ghostty && cp config/ghostty.config ~/.config/ghostty/config
#   Linux:  mkdir -p ~/.config/ghostty && cp config/ghostty.config ~/.config/ghostty/config
#
# Requires: Ghostty 1.1+ (https://ghostty.org)
# ============================================================================


# -- Font --------------------------------------------------------------------
# Size 11 maximizes information density — you're watching multiple agents
# work in split panes. Every row counts.
font-size = 11


# -- Theme -------------------------------------------------------------------
# Warm light background. High contrast for readability during long sessions.
# Matches Terminal.app "Exe" profile for consistency across terminals.
background = #fff8f0
foreground = #000000
cursor-color = #000000
selection-background = #b4d5fe


# -- ANSI palette (0-15) ----------------------------------------------------
# Standard terminal colors. These affect git diff, test output, error
# messages, and everything else that uses ANSI escape codes.
palette = 0=#000000
palette = 1=#c91b00
palette = 2=#00c200
palette = 3=#c7c400
palette = 4=#0225c7
palette = 5=#c930c7
palette = 6=#00c5c7
palette = 7=#c7c7c7
palette = 8=#686868
palette = 9=#ff6e67
palette = 10=#5ffa68
palette = 11=#e5daab
palette = 12=#6871ff
palette = 13=#ff77ff
palette = 14=#60fdff
palette = 15=#ffffff


# ============================================================================
# tmux keybindings
# ============================================================================
#
# exe-ai-employees uses tmux to run multiple AI agents in parallel.
# Each agent (yoshi, tom, mari) gets its own tmux window/pane.
#
# These keybindings forward Cmd+key to tmux as Ctrl+B (prefix) + key,
# so you get native macOS shortcuts instead of memorizing tmux combos.
#
# Your tmux prefix must be Ctrl+B (default). If you changed it,
# replace \x02 with your prefix's control code.
# ============================================================================


# -- Splits ------------------------------------------------------------------
# Cmd+D: split right — instantly open a new pane next to the current agent.
# Use this to watch two agents work side by side.
keybind = super+d=new_split:right

# Cmd+Shift+D: split down — stack panes vertically.
# Useful for a monitoring pane below the main agent.
keybind = super+shift+d=new_split:down

# Cmd+W: close the current pane/tab.
keybind = super+w=close_surface


# -- Tabs (tmux windows) ----------------------------------------------------
# Cmd+T: new tmux window (tab). Each employee typically gets one.
keybind = super+t=text:\x02t

# Cmd+Shift+[ and Cmd+Shift+]: cycle through tmux windows.
# Same shortcut as Safari/Chrome tab switching.
keybind = super+shift+[=text:\x02[
keybind = super+shift+]=text:\x02]

# Cmd+1 through Cmd+9: jump directly to tmux window by number.
# Window 1 = exe, 2 = yoshi, 3 = tom, etc.
# Both key name variants are bound for compatibility.
keybind = super+1=text:\x021
keybind = super+digit_1=text:\x021
keybind = super+2=text:\x022
keybind = super+digit_2=text:\x022
keybind = super+3=text:\x023
keybind = super+digit_3=text:\x023
keybind = super+4=text:\x024
keybind = super+digit_4=text:\x024
keybind = super+5=text:\x025
keybind = super+digit_5=text:\x025
keybind = super+6=text:\x026
keybind = super+digit_6=text:\x026
keybind = super+7=text:\x027
keybind = super+digit_7=text:\x027
keybind = super+8=text:\x028
keybind = super+digit_8=text:\x028
keybind = super+9=text:\x029


# -- Pane management ---------------------------------------------------------
# Cmd+Shift+Enter: zoom current pane to fullscreen (toggle).
# Focus on one agent's output, then un-zoom to see all panes again.
keybind = super+shift+enter=text:\x02z

# Cmd+K: clear the tmux pane scrollback.
# Clean slate between tasks — stops old output from confusing the agent.
keybind = super+k=text:\x02k

# Cmd+F: search tmux scrollback.
# Find a specific error, commit hash, or output from an agent's session.
keybind = super+f=text:\x02f

# Cmd+Ctrl+Arrows: resize splits.
# Drag pane borders to give more space to the agent you're watching.
keybind = super+ctrl+arrow_up=text:\x02\x1b[A
keybind = super+ctrl+arrow_down=text:\x02\x1b[B
keybind = super+ctrl+arrow_right=text:\x02\x1b[C
keybind = super+ctrl+arrow_left=text:\x02\x1b[D

# Cmd+Ctrl+=: equalize all split sizes.
# Reset layout after resizing — all panes get equal space.
keybind = super+ctrl+=text:\x02=
