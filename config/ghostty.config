# ============================================================================
# Ghostty config for exe-ai-employees
# ============================================================================
#
# A terminal built for running AI employees. Dark, focused, tmux-friendly.
#
# Install:
#   macOS:  cp config/ghostty.config ~/.config/ghostty/config
#   Linux:  cp config/ghostty.config ~/.config/ghostty/config
#
# Requires: Ghostty 1.1+ (https://ghostty.org)
# Font:     JetBrains Mono (https://www.jetbrains.com/lp/mono/)
#           Falls back to system monospace if not installed.
# ============================================================================

# -- Font --------------------------------------------------------------------
# JetBrains Mono: ligatures, clear at small sizes, wide Unicode coverage.
# Size 13 balances density with readability on Retina displays.
font-family = JetBrains Mono
font-size = 13

# -- Theme -------------------------------------------------------------------
# Deep blue-black background with soft contrast. Easy on the eyes during
# long sessions. The slight blue tint distinguishes terminal from editor.
background = 0e1019
foreground = c8ccd4

# Subtle transparency — enough to feel layered, not enough to distract.
# Remove this line if you prefer fully opaque.
background-opacity = 0.95

# -- Cursor ------------------------------------------------------------------
cursor-style = bar
cursor-style-blink = false

# -- Window ------------------------------------------------------------------
# Padding gives content room to breathe. Prevents text from touching edges.
window-padding-x = 8
window-padding-y = 4

# Native macOS tabs + decorations
macos-titlebar-style = transparent
window-decoration = auto

# -- Performance -------------------------------------------------------------
# Metal renderer on macOS. Ghostty uses GPU by default — these ensure it.
auto-update = check

# -- tmux integration --------------------------------------------------------
# exe-ai-employees uses tmux for multi-agent sessions.
# These settings prevent common tmux/terminal conflicts.

# Pass modifier keys correctly to tmux (ctrl+b prefix, etc.)
macos-option-as-alt = true

# Mouse support for tmux pane selection and scrollback
mouse-scroll-multiplier = 3

# -- Shell -------------------------------------------------------------------
# Don't override the user's shell. Ghostty uses login shell by default.
# Uncomment to force zsh if needed:
# command = /bin/zsh --login

# -- Clipboard ---------------------------------------------------------------
# Allow OSC 52 clipboard access — Claude Code and tmux use this for copy.
clipboard-read = allow
clipboard-write = allow

# -- Colors ------------------------------------------------------------------
# ANSI palette: muted tones that stay readable on the dark background.
# Based on a night-sky palette with purple/blue accents.

# Black (background shades)
palette = 0=#1a1b2e
palette = 8=#3b3d5c

# Red (errors, warnings)
palette = 1=#e06c75
palette = 9=#f07178

# Green (success, paths)
palette = 2=#98c379
palette = 10=#c3e88d

# Yellow (warnings, highlights)
palette = 3=#e5c07b
palette = 11=#ffcb6b

# Blue (info, links)
palette = 4=#61afef
palette = 12=#82aaff

# Magenta (exe branding accent)
palette = 5=#c678dd
palette = 13=#c792ea

# Cyan (strings, secondary)
palette = 6=#56b6c2
palette = 14=#89ddff

# White (foreground shades)
palette = 7=#abb2bf
palette = 15=#e8ecf2

# -- Selection ---------------------------------------------------------------
selection-foreground = e8ecf2
selection-background = 3b3d5c

# -- Quick terminal ----------------------------------------------------------
# Cmd+` for a quick drop-down terminal — useful for fast commands
# while Claude Code runs in the main window.
keybind = super+grave_accent=toggle_quick_terminal
